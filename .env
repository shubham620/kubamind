# KubeMind AI Environment Configuration

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development
DEBUG=true

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kubemind
POSTGRES_USER=kubemind_user
POSTGRES_PASSWORD=kubemind_secure_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Vector Database (Qdrant)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=test_api_key

# Kubernetes
KUBECONFIG_PATH=/home/user/.kube/config
K8S_NAMESPACE=default

# Prometheus
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_PORT=9090
PROMETHEUS_QUERY_TIMEOUT=30

# Grafana
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# Loki
LOKI_URL=http://loki:3100
LOKI_PORT=3100

# Node Exporter
NODE_EXPORTER_PORT=9100

# AI/LLM
LLM_MODEL=llama2
OLLAMA_URL=http://ollama:11434
OLLAMA_PORT=11434
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Monitoring Thresholds
CPU_THRESHOLD_HIGH=80
CPU_THRESHOLD_CRITICAL=95
MEMORY_THRESHOLD_HIGH=75
MEMORY_THRESHOLD_CRITICAL=90
DISK_THRESHOLD_HIGH=80
DISK_THRESHOLD_CRITICAL=95

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/kubemind.log

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Feature Flags
ENABLE_PREDICTIONS=true
ENABLE_CHAT_ASSISTANT=true
ENABLE_FAILURE_SIMULATION=true
